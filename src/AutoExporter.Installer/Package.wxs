<?xml version="1.0" encoding="utf-8"?>
<!--
  Auto Exporter (V2) installer. One MSI with two selectable features:

    Agent   - the agent Windows service plus the tray app (install on each export machine).
    Plugin  - the Management Client admin plugin (install on the management machine).

  The user can pick either or both on the feature page. The WiX v5 CLI (build.ps1 -Component
  installer) passes the three payload directories as preprocessor variables:
    AgentDir  : the agent net48 build output (service exe + Milestone runtime)
    TrayExe   : the published single file tray exe
    PluginDir : the admin plugin net48 build output (plugin dll + plugin.def + Admin\HelpPage.html)

  Plugin feature: closes the Management Client and stops/starts the Event Server around the file
  copy (the plugin DLL is locked while either runs), mirroring the reference MSC installer.

  Agent feature: shows a registration page (server, account, export folder, limits) and writes the
  machine config with a deferred action, so the service is already configured on its first start.
  The tray app is added to the Start menu and to per-machine autostart.

  Needs the WiX UI and Util extensions (build.ps1 adds them).
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util">

  <Package Name="Auto Exporter"
           Manufacturer="https://github.com/Cacsjep"
           Version="1.0.0.0"
           UpgradeCode="8F2C6D14-7A3B-4E59-9C20-1D4E6F8A2B70"
           Scope="perMachine"
           InstallerVersion="500"
           Compressed="yes">

    <MajorUpgrade DowngradeErrorMessage="A newer version of Auto Exporter is already installed."
                  Schedule="afterInstallInitialize" />
    <MediaTemplate EmbedCab="yes" CompressionLevel="high" />

    <Launch Condition="VersionNT64" Message="Auto Exporter requires a 64 bit version of Windows." />

    <!-- Feature-tree UI plus our registration page. -->
    <WixVariable Id="WixUILicenseRtf" Value="License.rtf" />
    <ui:WixUI Id="WixUI_FeatureTree" />

    <!-- Registration values collected on AgentConfigDlg. Secure so UI edits survive the hop to the
         execute (server-side) sequence. Sensible defaults. The password and the deferred command
         that carries it are Hidden so they stay out of the verbose MSI log. -->
    <Property Id="AGENT_SERVER" Secure="yes" />
    <Property Id="AGENT_AUTH" Secure="yes" Value="Basic" />
    <Property Id="AGENT_USER" Secure="yes" />
    <Property Id="AGENT_PASSWORD" Secure="yes" Hidden="yes" />
    <Property Id="AGENT_FOLDER" Secure="yes" Value="C:\AutoExporter" />
    <Property Id="AGENT_MAXGB" Secure="yes" Value="0" />
    <Property Id="AGENT_RETENTION" Secure="yes" Value="0" />
    <Property Id="CA_WriteAgentConfig" Hidden="yes" />

    <!-- ════════════════ Directories ════════════════ -->
    <StandardDirectory Id="ProgramFiles64Folder">
      <!-- Agent + tray -->
      <Directory Id="MSCPLUGINS" Name="MSCPlugins">
        <Directory Id="INSTALLFOLDER" Name="AutoExporterAgent">
          <Directory Id="TRAYFOLDER" Name="Tray" />
        </Directory>
      </Directory>
      <!-- Admin plugin (Milestone MIP plugin host scans here) -->
      <Directory Id="MILESTONEDIR" Name="Milestone">
        <Directory Id="MIPPLUGINS" Name="MIPPlugins">
          <Directory Id="PLUGINFOLDER" Name="AutoExporterV2" />
        </Directory>
      </Directory>
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="AppShortcutDir" Name="Auto Exporter" />
    </StandardDirectory>

    <!-- ════════════════ Features ════════════════ -->
    <Feature Id="FeatureAgent" Title="Agent service and tray app"
             Description="The export service and its tray configuration app. Install on each machine that produces exports."
             Level="1" ConfigurableDirectory="INSTALLFOLDER">
      <ComponentRef Id="AgentExe" />
      <ComponentGroupRef Id="AgentRuntime" />
      <ComponentRef Id="TrayApp" />
    </Feature>

    <Feature Id="FeaturePlugin" Title="Management Client plugin"
             Description="The admin plugin that defines jobs and shows status. Install on the management machine. Closes the Management Client and restarts the Event Server during install."
             Level="1">
      <ComponentGroupRef Id="PluginFiles" />
    </Feature>

    <!-- ════════════════ Custom actions ════════════════ -->

    <!-- Close the Management Client so its lock on the plugin DLL is released before the copy. -->
    <SetProperty Id="CA_StopManagementClient"
                 Before="CA_StopManagementClient" Sequence="execute"
                 Value="&quot;[System64Folder]cmd.exe&quot; /c taskkill /F /IM &quot;VideoOS.Administration.exe&quot; 2&gt;nul &amp; taskkill /F /IM &quot;VideoOS.Platform.Administration.exe&quot; 2&gt;nul &amp; exit /b 0" />
    <CustomAction Id="CA_StopManagementClient"
                  DllEntry="WixQuietExec64" BinaryRef="Wix4UtilCA_X86"
                  Execute="deferred" Impersonate="no" Return="ignore" />

    <!-- Stop the Event Server (net stop waits for it to actually stop). -->
    <SetProperty Id="CA_StopEventServer"
                 Before="CA_StopEventServer" Sequence="execute"
                 Value="&quot;[System64Folder]cmd.exe&quot; /c net stop MilestoneEventServerService /y 2&gt;nul &amp; exit /b 0" />
    <CustomAction Id="CA_StopEventServer"
                  DllEntry="WixQuietExec64" BinaryRef="Wix4UtilCA_X86"
                  Execute="deferred" Impersonate="no" Return="ignore" />

    <!-- Start the Event Server again after the copy so it loads the (new) plugin. -->
    <SetProperty Id="CA_StartEventServer"
                 Before="CA_StartEventServer" Sequence="execute"
                 Value="&quot;[System64Folder]cmd.exe&quot; /c net start MilestoneEventServerService 2&gt;nul &amp; exit /b 0" />
    <CustomAction Id="CA_StartEventServer"
                  DllEntry="WixQuietExec64" BinaryRef="Wix4UtilCA_X86"
                  Execute="deferred" Impersonate="no" Return="ignore" />

    <!-- Pre-write the agent machine config from the registration page, as LocalSystem (the account
         the service runs as), reusing the agent's own config writer so format and DPAPI match. -->
    <SetProperty Id="CA_WriteAgentConfig"
                 Before="CA_WriteAgentConfig" Sequence="execute"
                 Value="&quot;[INSTALLFOLDER]AutoExporter.Agent.exe&quot; --configure --server=&quot;[AGENT_SERVER]&quot; --auth=[AGENT_AUTH] --user=&quot;[AGENT_USER]&quot; --password=&quot;[AGENT_PASSWORD]&quot; --folder=&quot;[AGENT_FOLDER]&quot; --maxgb=[AGENT_MAXGB] --retention=[AGENT_RETENTION]" />
    <CustomAction Id="CA_WriteAgentConfig"
                  DllEntry="WixQuietExec64" BinaryRef="Wix4UtilCA_X86"
                  Execute="deferred" Impersonate="no" Return="ignore" />

    <!-- ════════════════ Install sequence ════════════════
         Plugin feature: close MC + stop ES before files, start ES after.
         Agent feature: write config after files, before the service starts.
         &FeaturePlugin / &FeatureAgent = 3 means the feature is being installed in this run,
         = 2 means it is being removed. -->
    <InstallExecuteSequence>
      <!-- Plugin install, plugin feature removal, and full uninstall all need the Management Client
           closed (it locks the plugin DLL) and the Event Server stopped before the files change.
           &FeaturePlugin=2 already covers both feature removal and full uninstall. -->
      <Custom Action="CA_StopManagementClient" Before="CA_StopEventServer"
              Condition="(&amp;FeaturePlugin=3 OR &amp;FeaturePlugin=2)" />
      <Custom Action="CA_StopEventServer" Before="InstallFiles"
              Condition="(&amp;FeaturePlugin=3 OR &amp;FeaturePlugin=2)" />

      <Custom Action="CA_WriteAgentConfig" After="InstallFiles"
              Condition="&amp;FeatureAgent=3 AND AGENT_SERVER&lt;&gt;&quot;&quot;" />

      <Custom Action="CA_StartEventServer" After="InstallFiles"
              Condition="(&amp;FeaturePlugin=3 OR &amp;FeaturePlugin=2)" />
    </InstallExecuteSequence>

    <!-- ════════════════ Registration page UI ════════════════ -->
    <UI>
      <ProgressText Action="CA_StopManagementClient" Message="Closing the XProtect Management Client..." />
      <ProgressText Action="CA_StopEventServer" Message="Stopping the Milestone Event Server..." />
      <ProgressText Action="CA_StartEventServer" Message="Starting the Milestone Event Server..." />
      <ProgressText Action="CA_WriteAgentConfig" Message="Writing the agent configuration..." />

      <Dialog Id="AgentConfigDlg" Width="370" Height="270" Title="[ProductName] Setup">
        <Control Id="BannerBitmap" Type="Bitmap" X="0" Y="0" Width="370" Height="44"
                 TabSkip="no" Text="!(loc.InstallDirDlgBannerBitmap)" />
        <Control Id="BannerLine" Type="Line" X="0" Y="44" Width="370" Height="0" />
        <Control Id="BottomLine" Type="Line" X="0" Y="234" Width="370" Height="0" />

        <Control Id="Title" Type="Text" X="15" Y="6" Width="340" Height="15"
                 Transparent="yes" NoPrefix="yes" Text="{\DlgTitleFont}Agent registration" />
        <Control Id="Description" Type="Text" X="25" Y="23" Width="340" Height="15"
                 Transparent="yes" Text="The service signs in to Milestone with these details on first start." />

        <Control Id="ServerLabel" Type="Text" X="25" Y="55" Width="85" Height="12"
                 Transparent="yes" Text="Management server" />
        <Control Id="ServerEdit" Type="Edit" X="115" Y="53" Width="230" Height="16" Property="AGENT_SERVER" />

        <Control Id="AuthLabel" Type="Text" X="25" Y="80" Width="85" Height="12"
                 Transparent="yes" Text="Authentication" />
        <Control Id="AuthGroup" Type="RadioButtonGroup" X="113" Y="78" Width="232" Height="34" Property="AGENT_AUTH">
          <RadioButtonGroup Property="AGENT_AUTH">
            <RadioButton Value="Basic" X="0" Y="0" Width="230" Height="15" Text="Basic user" />
            <RadioButton Value="WindowsOtherUser" X="0" Y="16" Width="230" Height="15" Text="Windows user (DOMAIN\user or user@domain)" />
          </RadioButtonGroup>
        </Control>

        <Control Id="UserLabel" Type="Text" X="25" Y="118" Width="85" Height="12"
                 Transparent="yes" Text="Username" />
        <Control Id="UserEdit" Type="Edit" X="115" Y="116" Width="230" Height="16" Property="AGENT_USER" />

        <Control Id="PwLabel" Type="Text" X="25" Y="139" Width="85" Height="12"
                 Transparent="yes" Text="Password" />
        <Control Id="PwEdit" Type="Edit" X="115" Y="137" Width="230" Height="16" Password="yes" Property="AGENT_PASSWORD" />

        <Control Id="FolderLabel" Type="Text" X="25" Y="160" Width="85" Height="12"
                 Transparent="yes" Text="Export folder" />
        <Control Id="FolderEdit" Type="Edit" X="115" Y="158" Width="230" Height="16" Property="AGENT_FOLDER" />

        <Control Id="MaxGbLabel" Type="Text" X="25" Y="181" Width="85" Height="12"
                 Transparent="yes" Text="Max size GB (0 = unlimited)" />
        <Control Id="MaxGbEdit" Type="Edit" X="115" Y="179" Width="60" Height="16" Property="AGENT_MAXGB" />

        <Control Id="RetLabel" Type="Text" X="190" Y="181" Width="80" Height="12"
                 Transparent="yes" Text="Retention days (0 = unlimited)" />
        <Control Id="RetEdit" Type="Edit" X="285" Y="179" Width="60" Height="16" Property="AGENT_RETENTION" />

        <Control Id="Hint" Type="Text" X="25" Y="205" Width="320" Height="24" Transparent="yes"
                 Text="You can leave these blank and configure later from the tray app. Changes here apply on the next service start." />

        <Control Id="Back" Type="PushButton" X="180" Y="243" Width="56" Height="17" Text="&amp;Back">
          <Publish Event="NewDialog" Value="CustomizeDlg" Condition="1" />
        </Control>
        <Control Id="Next" Type="PushButton" X="236" Y="243" Width="56" Height="17" Default="yes" Text="&amp;Next">
          <Publish Event="NewDialog" Value="VerifyReadyDlg" Condition="1" />
        </Control>
        <Control Id="Cancel" Type="PushButton" X="304" Y="243" Width="56" Height="17" Cancel="yes" Text="Cancel">
          <Publish Event="SpawnDialog" Value="CancelDlg" Condition="1" />
        </Control>
      </Dialog>

      <!-- Splice AgentConfigDlg between feature selection and the ready page, but only when the
           Agent feature is being installed. Higher Order beats the stock WixUI navigation. -->
      <Publish Dialog="CustomizeDlg" Control="Next" Event="NewDialog"
               Value="AgentConfigDlg" Order="10" Condition="&amp;FeatureAgent=3" />
      <Publish Dialog="VerifyReadyDlg" Control="Back" Event="NewDialog"
               Value="AgentConfigDlg" Order="10" Condition="&amp;FeatureAgent=3" />
    </UI>
  </Package>

  <!-- ════════════════ Agent payload ════════════════ -->
  <Fragment>
    <Component Id="AgentExe" Directory="INSTALLFOLDER" Bitness="always64">
      <File Id="filAgentExe" Source="$(var.AgentDir)\AutoExporter.Agent.exe" KeyPath="yes" />
      <ServiceInstall Id="svcInstall"
                      Name="AutoExporterAgent"
                      DisplayName="Auto Exporter Agent"
                      Description="Performs Milestone XProtect exports on this machine."
                      Type="ownProcess"
                      Start="auto"
                      ErrorControl="normal"
                      Account="LocalSystem"
                      Vital="yes" />
      <ServiceControl Id="svcCtl"
                      Name="AutoExporterAgent"
                      Start="install"
                      Stop="both"
                      Remove="uninstall"
                      Wait="yes" />
    </Component>

    <!-- Everything else in the agent output (Milestone runtime, config dlls), minus the exe and pdbs. -->
    <ComponentGroup Id="AgentRuntime" Directory="INSTALLFOLDER">
      <Files Include="$(var.AgentDir)\**">
        <Exclude Files="$(var.AgentDir)\AutoExporter.Agent.exe" />
        <Exclude Files="$(var.AgentDir)\**\*.pdb" />
      </Files>
    </ComponentGroup>

    <!-- The tray app, with a Start menu shortcut and run at login for all users. -->
    <Component Id="TrayApp" Directory="TRAYFOLDER" Bitness="always64">
      <File Id="filTrayExe" Source="$(var.TrayExe)" KeyPath="yes" />

      <Shortcut Id="scTrayStartMenu"
                Directory="AppShortcutDir"
                Name="Auto Exporter Agent"
                Description="Configure and control the Auto Exporter Agent service"
                Target="[#filTrayExe]"
                WorkingDirectory="TRAYFOLDER" />
      <RemoveFolder Id="rmAppShortcutDir" Directory="AppShortcutDir" On="uninstall" />

      <RegistryValue Root="HKLM"
                     Key="Software\Microsoft\Windows\CurrentVersion\Run"
                     Name="AutoExporterTray"
                     Type="string"
                     Value="&quot;[#filTrayExe]&quot;" />
    </Component>
  </Fragment>

  <!-- ════════════════ Plugin payload ════════════════ -->
  <Fragment>
    <!-- The whole plugin output (dll, plugin.def, Admin\HelpPage.html, deps), minus pdbs. The
         relative subfolders (Admin\) are preserved by the harvest. -->
    <ComponentGroup Id="PluginFiles" Directory="PLUGINFOLDER">
      <Files Include="$(var.PluginDir)\**">
        <Exclude Files="$(var.PluginDir)\**\*.pdb" />
      </Files>
    </ComponentGroup>
  </Fragment>
</Wix>

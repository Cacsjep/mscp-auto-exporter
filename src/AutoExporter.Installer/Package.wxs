<?xml version="1.0" encoding="utf-8"?>
<!--
  Auto Exporter installer. One MSI with two selectable features:

    Agent   - the agent Windows service plus the tray app (install on each export machine).
    Plugin  - the Management Client admin plugin (install on the management machine).

  The user can pick either or both on the feature page. The WiX v5 CLI (build.ps1 -Component
  installer) passes the three payload directories as preprocessor variables:
    AgentDir  : the agent net48 build output (service exe + Milestone runtime)
    TrayExe   : the published single file tray exe
    PluginDir : the admin plugin net48 build output (plugin dll + plugin.def + Admin\HelpPage.html)

  Plugin feature: closes the Management Client and stops/starts the Event Server around the file
  copy (the plugin DLL is locked while either runs), mirroring the reference MSC installer.

  Agent feature: installs the service and tray. The tray is added to the Start menu, the Desktop,
  and per-machine autostart, and can be launched from the finish page. The Milestone connection and
  export settings are configured later in the tray, not during install.

  Needs the WiX UI and Util extensions (build.ps1 adds them).
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util">

  <Package Name="Auto Exporter"
           Manufacturer="MSC Community Plugins"
           Version="$(var.Version)"
           UpgradeCode="8F2C6D14-7A3B-4E59-9C20-1D4E6F8A2B70"
           Scope="perMachine"
           InstallerVersion="500"
           Compressed="yes">

    <MajorUpgrade DowngradeErrorMessage="A newer version of Auto Exporter is already installed."
                  Schedule="afterInstallInitialize" />
    <MediaTemplate EmbedCab="yes" CompressionLevel="high" />

    <Launch Condition="VersionNT64" Message="Auto Exporter requires a 64 bit version of Windows." />

    <!-- Feature-tree UI. -->
    <WixVariable Id="WixUILicenseRtf" Value="License.rtf" />
    <ui:WixUI Id="WixUI_FeatureTree" />

    <!-- Offer to launch the tray from the finish page (checked by default). The checkbox only
         appears when the Agent feature is installed (the text is set conditionally below). The
         launch runs impersonated so the tray lands in the installing user's notification area. -->
    <Property Id="WIXUI_EXITDIALOGOPTIONALCHECKBOX" Value="1" />
    <Property Id="WixShellExecTarget" Value="[#filTrayExe]" />
    <CustomAction Id="LaunchTray" BinaryRef="Wix4UtilCA_X86" DllEntry="WixShellExec"
                  Execute="immediate" Impersonate="yes" Return="ignore" />
    <SetProperty Id="WIXUI_EXITDIALOGOPTIONALCHECKBOXTEXT" Value="Launch the Auto Exporter tray now"
                 After="CostFinalize" Sequence="ui" Condition="&amp;FeatureAgent=3" />

    <!-- ================ Directories ================ -->
    <StandardDirectory Id="ProgramFiles64Folder">
      <!-- Agent + tray -->
      <Directory Id="MSCPLUGINS" Name="MSCPlugins">
        <Directory Id="INSTALLFOLDER" Name="AutoExporter">
          <Directory Id="TRAYFOLDER" Name="Tray" />
        </Directory>
      </Directory>
      <!-- Admin plugin (Milestone MIP plugin host scans here) -->
      <Directory Id="MILESTONEDIR" Name="Milestone">
        <Directory Id="MIPPLUGINS" Name="MIPPlugins">
          <Directory Id="PLUGINFOLDER" Name="AutoExporter" />
        </Directory>
      </Directory>
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="AppShortcutDir" Name="Auto Exporter" />
    </StandardDirectory>

    <StandardDirectory Id="DesktopFolder" />

    <!-- ================ Features ================ -->
    <Feature Id="FeatureAgent" Title="Agent service and tray app"
             Description="The export service and its tray configuration app. Install on each machine that produces exports."
             Level="1" ConfigurableDirectory="INSTALLFOLDER">
      <ComponentRef Id="AgentExe" />
      <ComponentGroupRef Id="AgentRuntime" />
      <ComponentRef Id="TrayApp" />
    </Feature>

    <Feature Id="FeaturePlugin" Title="Management Client plugin"
             Description="The admin plugin that defines jobs and shows status. Install on the management machine. Closes the Management Client and restarts the Event Server during install."
             Level="1">
      <ComponentGroupRef Id="PluginFiles" />
    </Feature>

    <!-- ================ Custom actions ================ -->

    <!-- Close the Management Client so its lock on the plugin DLL is released before the copy. -->
    <SetProperty Id="CA_StopManagementClient"
                 Before="CA_StopManagementClient" Sequence="execute"
                 Value="&quot;[System64Folder]cmd.exe&quot; /c taskkill /F /IM &quot;VideoOS.Administration.exe&quot; 2&gt;nul &amp; taskkill /F /IM &quot;VideoOS.Platform.Administration.exe&quot; 2&gt;nul &amp; exit /b 0" />
    <CustomAction Id="CA_StopManagementClient"
                  DllEntry="WixQuietExec64" BinaryRef="Wix4UtilCA_X86"
                  Execute="deferred" Impersonate="no" Return="ignore" />

    <!-- Stop the Event Server (net stop waits for it to actually stop). -->
    <SetProperty Id="CA_StopEventServer"
                 Before="CA_StopEventServer" Sequence="execute"
                 Value="&quot;[System64Folder]cmd.exe&quot; /c net stop MilestoneEventServerService /y 2&gt;nul &amp; exit /b 0" />
    <CustomAction Id="CA_StopEventServer"
                  DllEntry="WixQuietExec64" BinaryRef="Wix4UtilCA_X86"
                  Execute="deferred" Impersonate="no" Return="ignore" />

    <!-- Start the Event Server again after the copy so it loads the (new) plugin. -->
    <SetProperty Id="CA_StartEventServer"
                 Before="CA_StartEventServer" Sequence="execute"
                 Value="&quot;[System64Folder]cmd.exe&quot; /c net start MilestoneEventServerService 2&gt;nul &amp; exit /b 0" />
    <CustomAction Id="CA_StartEventServer"
                  DllEntry="WixQuietExec64" BinaryRef="Wix4UtilCA_X86"
                  Execute="deferred" Impersonate="no" Return="ignore" />

    <!-- Kill any running tray before files change, so an upgrade can replace it and an uninstall
         can remove it (a running tray locks AutoExporter.Tray.exe). Runs as SYSTEM, which can end a
         process in the user's session. -->
    <SetProperty Id="CA_StopTray"
                 Before="CA_StopTray" Sequence="execute"
                 Value="&quot;[System64Folder]cmd.exe&quot; /c taskkill /F /IM &quot;AutoExporter.Tray.exe&quot; 2&gt;nul &amp; exit /b 0" />
    <CustomAction Id="CA_StopTray"
                  DllEntry="WixQuietExec64" BinaryRef="Wix4UtilCA_X86"
                  Execute="deferred" Impersonate="no" Return="ignore" />

    <!-- On a genuine uninstall (not an upgrade), remove the runtime data folder (config, state,
         logs) so nothing of ours is left behind. Exported video is NOT here (it lives in the
         user-chosen export folder), so it is never touched. -->
    <SetProperty Id="CA_RemoveData"
                 Before="CA_RemoveData" Sequence="execute"
                 Value="&quot;[System64Folder]cmd.exe&quot; /c rmdir /s /q &quot;[CommonAppDataFolder]MSCPlugins\AutoExporter&quot; 2&gt;nul &amp; exit /b 0" />
    <CustomAction Id="CA_RemoveData"
                  DllEntry="WixQuietExec64" BinaryRef="Wix4UtilCA_X86"
                  Execute="deferred" Impersonate="no" Return="ignore" />

    <!-- ================ Install sequence ================
         Plugin feature: close MC + stop ES before files, start ES after.
         &FeaturePlugin = 3 means the feature is being installed in this run, = 2 means removed. -->
    <InstallExecuteSequence>
      <!-- Kill the tray before any file operation, so its exe is never locked when files change
           (RemoveFiles on uninstall, InstallFiles on a fresh install or upgrade). This must run
           AFTER RemoveExistingProducts: a deferred custom action sequenced before it triggers
           Windows Installer error 2613 (RemoveExistingProducts sequenced incorrectly). On an
           upgrade the old tray is closed by the previous version's own copy of this action while
           RemoveExistingProducts uninstalls it. -->
      <Custom Action="CA_StopTray" Before="RemoveFiles" />

      <!-- Plugin install, plugin feature removal, and full uninstall all need the Management Client
           closed (it locks the plugin DLL) and the Event Server stopped before the files change.
           &FeaturePlugin=2 already covers both feature removal and full uninstall. -->
      <Custom Action="CA_StopManagementClient" Before="CA_StopEventServer"
              Condition="(&amp;FeaturePlugin=3 OR &amp;FeaturePlugin=2)" />
      <Custom Action="CA_StopEventServer" Before="InstallFiles"
              Condition="(&amp;FeaturePlugin=3 OR &amp;FeaturePlugin=2)" />

      <Custom Action="CA_StartEventServer" After="InstallFiles"
              Condition="(&amp;FeaturePlugin=3 OR &amp;FeaturePlugin=2)" />

      <!-- Genuine uninstall only: REMOVE=ALL but not while the old product is being removed as part
           of an upgrade (UPGRADINGPRODUCTCODE), so config and logs survive upgrades. -->
      <Custom Action="CA_RemoveData" After="RemoveFiles"
              Condition="REMOVE=&quot;ALL&quot; AND NOT UPGRADINGPRODUCTCODE" />
    </InstallExecuteSequence>

    <!-- ================ UI tweaks ================ -->
    <UI>
      <ProgressText Action="CA_StopTray" Message="Closing the Auto Exporter tray..." />
      <ProgressText Action="CA_RemoveData" Message="Removing Auto Exporter data..." />
      <ProgressText Action="CA_StopManagementClient" Message="Closing the XProtect (TM) Management Client..." />
      <ProgressText Action="CA_StopEventServer" Message="Stopping the Milestone Event Server..." />
      <ProgressText Action="CA_StartEventServer" Message="Starting the Milestone Event Server..." />

      <!-- Launch the tray when the user clicks Finish, if they left the box checked and the Agent
           feature was actually installed in this run. -->
      <Publish Dialog="ExitDialog" Control="Finish" Event="DoAction" Value="LaunchTray"
               Condition="WIXUI_EXITDIALOGOPTIONALCHECKBOX = 1 AND NOT Installed AND &amp;FeatureAgent=3" />
    </UI>
  </Package>

  <!-- ================ Agent payload ================ -->
  <Fragment>
    <Component Id="AgentExe" Directory="INSTALLFOLDER" Bitness="always64">
      <File Id="filAgentExe" Source="$(var.AgentDir)\AutoExporter.Agent.exe" KeyPath="yes" />
      <ServiceInstall Id="svcInstall"
                      Name="AutoExporterAgent"
                      DisplayName="Auto Exporter Agent"
                      Description="Performs Milestone XProtect (TM) exports on this machine."
                      Type="ownProcess"
                      Start="auto"
                      ErrorControl="normal"
                      Account="LocalSystem"
                      Vital="yes" />
      <ServiceControl Id="svcCtl"
                      Name="AutoExporterAgent"
                      Start="install"
                      Stop="both"
                      Remove="uninstall"
                      Wait="yes" />
    </Component>

    <!-- Everything else in the agent output (Milestone runtime, config dlls), minus the exe and pdbs. -->
    <ComponentGroup Id="AgentRuntime" Directory="INSTALLFOLDER">
      <Files Include="$(var.AgentDir)\**">
        <Exclude Files="$(var.AgentDir)\AutoExporter.Agent.exe" />
        <Exclude Files="$(var.AgentDir)\**\*.pdb" />
      </Files>
    </ComponentGroup>

    <!-- The tray app, with a Start menu shortcut and run at login for all users. -->
    <Component Id="TrayApp" Directory="TRAYFOLDER" Bitness="always64">
      <File Id="filTrayExe" Source="$(var.TrayExe)" KeyPath="yes" />

      <Shortcut Id="scTrayStartMenu"
                Directory="AppShortcutDir"
                Name="Auto Exporter Agent"
                Description="Configure and control the Auto Exporter Agent service"
                Target="[#filTrayExe]"
                WorkingDirectory="TRAYFOLDER" />
      <RemoveFolder Id="rmAppShortcutDir" Directory="AppShortcutDir" On="uninstall" />

      <!-- Desktop shortcut so the user finds it without digging into the Start menu. -->
      <Shortcut Id="scTrayDesktop"
                Directory="DesktopFolder"
                Name="Auto Exporter Agent"
                Description="Configure and control the Auto Exporter Agent service"
                Target="[#filTrayExe]"
                WorkingDirectory="TRAYFOLDER" />

      <RegistryValue Root="HKLM"
                     Key="Software\Microsoft\Windows\CurrentVersion\Run"
                     Name="AutoExporterTray"
                     Type="string"
                     Value="&quot;[#filTrayExe]&quot;" />
    </Component>
  </Fragment>

  <!-- ================ Plugin payload ================ -->
  <Fragment>
    <!-- The whole plugin output (dll, plugin.def, Admin\HelpPage.html, deps), minus pdbs. The
         relative subfolders (Admin\) are preserved by the harvest. -->
    <ComponentGroup Id="PluginFiles" Directory="PLUGINFOLDER">
      <Files Include="$(var.PluginDir)\**">
        <Exclude Files="$(var.PluginDir)\**\*.pdb" />
      </Files>
    </ComponentGroup>
  </Fragment>
</Wix>


